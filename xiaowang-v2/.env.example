# =====================================================================
# 小王 v2 环境变量样板 —— 复制为 .env 后填值。
#   cp .env.example .env  &&  编辑 .env
# 库里只存 epoch ms、JSON TEXT；这里只放运行时配置。
# 留空的项各模块有默认值（见契约「环境变量」节）；标 [必填] 的不填会降级或报警。
# =====================================================================

# ---- 持久化 ----
# v2 数据库路径。WAL 不支持 :memory:，selftest 自己指临时文件，这里别填 :memory:。
XW2_DB_PATH=/opt/xiaowang-v2/v2.db
# read_file/write_file 工具的沙箱根。越界访问被 resolveSandboxPath 拦死。
XW2_SANDBOX_DIR=/opt/xiaowang-v2/workspace

# ---- LLM 主 provider (OpenAI 兼容 /chat/completions，纯 fetch) ----
# [必填] 留空 LLM_API_KEY → USE_MOCK=true，小王不联网只走 mock（部署后记得填）。
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
# DeepSeek 现役模型：deepseek-v4-pro（用它）/ deepseek-v4-flash。deepseek-chat 已并入 flash 并将于 2026-07-24 退名，勿用。
LLM_MODEL=deepseek-v4-pro
# =1 强制离线 mock（不联网），调试/自检用。生产留空。
LLM_MOCK=
# LLM fetch 超时（ms）。致命纪律②：外部调用必带 timeout，绝不无限等。
LLM_TIMEOUT_MS=30000

# ---- LLM fallback provider (主 provider 连续失败后 callWithResilience 切这个) ----
# Kimi / Moonshot，同样 OpenAI 兼容。
LLM_FALLBACK_BASE_URL=https://api.moonshot.cn/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=moonshot-v1-8k

# ---- http_get 工具 / 企微 API 的 HTTP 超时（ms） ----
HTTP_TIMEOUT_MS=15000

# =====================================================================
# 企微发送凭证（adapter.mjs / watchdog 报警复用）
# -------------------------------------------------------------------
# 现有 live ESM bot 走的是【e云企微 / qiweapi.com】token 体系，不是腾讯官方
# corpid+secret。v2 复用同一套，所以下面给两组：
#   A) e云企微（当前服务器实际在用，优先填这组）
#   B) 腾讯官方 corpid/secret（备选，adapter 若实现官方通道时用）
# adapter.sendWecom 按 WECOM_API_URL 决定走哪条；ADAPTER_MOCK=1 时一律不真发。
# =====================================================================

# ---- A) e云企微 (qiweapi.com) —— 推荐，与 esm-bot 同体系 ----
# 发消息/报警 API 地址。e云默认值如下；adapter 用 WECOM_API_URL 读它。
WECOM_API_URL=http://manager.qiweapi.com/qiwe/api/qw/doApi
# [必填-A] e云鉴权 token（HTTP header X-QIWEI-TOKEN）。沿用 esm-bot 的 QIWE_TOKEN 值。
WECOM_TOKEN=
# e云企微账号 GUID（doApi 入参 guid）。沿用 esm-bot 的 QIWE_GUID 值。
WECOM_GUID=

# ---- B) 腾讯官方 corpid/secret（备选，A 填了就不用 B）----
WECOM_CORPID=
WECOM_SECRET=
WECOM_AGENTID=

# ---- 收件人（n=1，只有子淇一个 owner）----
# [必填] 子淇在企微里的 sender/external id。所有 send_message / 报警发到这个 id。
# 同时也是 agentic 工具循环里识别「主人」的 OWNER_ID（危险操作授权基准）。
WECOM_TARGET_ID=
OWNER_ID=

# =1 时 sendWecom 不真发，入内存 SENT 数组（selftest / 烟测用）。生产留空。
ADAPTER_MOCK=

# ---- 入站安全 / 合并 ----
# 回调密钥路径：配了则 POST 必须命中 /cb/<secret>（公网端口防伪造注入）。e云【设置回调地址】里也填带 secret 的完整 URL。
WECOM_CALLBACK_SECRET=
# 轮次装配·安静窗口（ms）：每来一条消息重置计时，窗口内没新消息才认为"这一串说完了"。
DEBOUNCE_MS=4000
# 轮次装配·下载栅栏上限（ms）：窗口到了但图/语音还在下载识别时最多再等这么久（卡死不无限扣轮）。
MEDIA_FENCE_MAX_MS=30000

# =====================================================================
# 媒体（图片/语音）——P2。两层：原始字节落盘(不可逆) + 文本描述/转写(可再生)。
# 下载复用上面的 WECOM_TOKEN/WECOM_GUID（e云 doApi）。
# =====================================================================
# 原始媒体落盘目录（不可逆 artifact，原则9 绝不自动删）。留空=<模块目录>/media。
MEDIA_DIR=
# 图像识别(视觉)：OpenAI 兼容 chat/completions。默认 kimi 视觉；留空 VISION_API_KEY → 图片只落盘不识别。
VISION_API_URL=https://api.moonshot.cn/v1/chat/completions
VISION_API_KEY=
VISION_MODEL=kimi-k2.5
# 语音转写：=xfyun 启用讯飞「中英识别大模型」；留空=只存音频不转写（音频零丢失，可后补转）。
# 依赖 ffmpeg（外部进程，ECS 需装；缺则语音降级只存音频+回执）。
VOICE_ASR=
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# =====================================================================
# 运行时
# =====================================================================
# HTTP 回调端口。契约钉死 8090（与 live esm-bot 的 8080 错开，并行共存）。
# 注意：契约「环境变量」节文字写默认 8788，但本项目最终选型钉死 8090，以 service / install 为准。
HTTP_PORT=8090

# =1 切 pino JSON 行日志（需 npm i pino，可选依赖）；留空走纯 console。
LOG_JSON=
