# 朋友实例 .env 模板（路2 隔离）。复制成 friend.env 填好，放 /opt/xiaowang-v2/friend.env（gitignored）。
# 与子淇共用同一个 e云企微号（同 TOKEN/GUID），区别只在：OWNER 不同、端口不同、库不同、身份不同、媒体/沙箱目录不同。

# —— 渠道（与子淇同一个企微号）——
WECOM_TOKEN=<同子淇那份>
WECOM_GUID=<同子淇那份>
WECOM_API_URL=http://manager.qiweapi.com/qiwe/api/qw/doApi

# —— 朋友自己的身份 + 隔离 ——
OWNER_ID=<朋友的微信 senderId>
WECOM_TARGET_ID=<朋友的微信 senderId>
WECOM_CALLBACK_SECRET=<朋友后端独立 secret，与子淇后端不同>
HTTP_PORT=8082
XW2_IDENTITY=friend
XW2_DB_PATH=/opt/xiaowang-v2/tenants/friend/v2.db
XW2_SANDBOX_DIR=/opt/xiaowang-v2/tenants/friend/workspace
MEDIA_DIR=/opt/xiaowang-v2/tenants/friend/media

# —— 共享服务 key（非个人信息；账单算子淇，朋友也可自备替换）——
LLM_API_KEY=<同子淇 或 朋友自备>
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
LLM_FALLBACK_API_KEY=<同子淇>
LLM_FALLBACK_BASE_URL=https://api.moonshot.cn/v1
LLM_FALLBACK_MODEL=moonshot-v1-8k
VISION_API_KEY=<同子淇>
VOICE_ASR=xfyun
XFYUN_APP_ID=<同子淇>
XFYUN_API_KEY=<同子淇>
XFYUN_API_SECRET=<同子淇>
GAODE_KEY=<必配；留空则天气功能不可用>
HTTP_TIMEOUT_MS=15000
DEBOUNCE_MS=4000
